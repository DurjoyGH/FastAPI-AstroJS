---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "FC | Football Chatbot",
	description = "A premium AI-powered football chatbot for tactical analysis and insights.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#09090b] text-white antialiased selection:bg-brand-500/30 selection:text-brand-100 min-h-screen flex flex-col">
		<div class="fixed inset-0 z-[-1] bg-[#09090b]">
			<!-- Subtle ambient background glow -->
			<div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-brand-900/20 blur-[120px] mix-blend-screen pointer-events-none"></div>
			<div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] rounded-full bg-blue-900/10 blur-[120px] mix-blend-screen pointer-events-none"></div>
		</div>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	* {
		box-sizing: border-box;
	}
</style>
